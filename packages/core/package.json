{
  "name": "@leclabs/agentir-core",
  "version": "0.0.0",
  "description": "agentir IR types, schema, and engine",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": ["dist", "schema"],
  "scripts": {
    "gen": "tsx scripts/generate-types.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist src/ir/generated.ts"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "gray-matter": "catalog:",
    "js-yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:",
    "json-schema-to-typescript": "^15.0.0",
    "tsup": "catalog:",
    "tsx": "^4.19.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
