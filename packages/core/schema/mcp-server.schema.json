{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leclabs.dev/agentir/v1/mcp-server.schema.json",
  "title": "McpServer",
  "description": "An MCP server registration. Stdio servers use command+args; remote servers use url. Discriminated by transport.",
  "oneOf": [
    { "$ref": "#/$defs/StdioMcpServer" },
    { "$ref": "#/$defs/RemoteMcpServer" }
  ],
  "$defs": {
    "StdioMcpServer": {
      "title": "StdioMcpServer",
      "type": "object",
      "required": ["name", "transport", "command"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "transport": { "const": "stdio" },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "targets": { "type": "array", "items": { "type": "string" } },
        "excludes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "RemoteMcpServer": {
      "title": "RemoteMcpServer",
      "type": "object",
      "required": ["name", "transport", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "transport": { "enum": ["sse", "http"] },
        "url": { "type": "string", "format": "uri" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "targets": { "type": "array", "items": { "type": "string" } },
        "excludes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
